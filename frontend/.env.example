# Backend base URL (no trailing slash). Vite bakes this in at build time.
#
# Local dev (HTTP → HTTP is fine):
#   VITE_API_URL=http://127.0.0.1:8000
#
# Vercel / HTTPS frontend: do NOT point at http:// EC2 from the browser (mixed content).
# Use the same-origin proxy from vercel.json instead:
#   VITE_API_URL=/api
#
# Or use a public HTTPS API URL:
#   VITE_API_URL=https://api.yourdomain.com
VITE_API_URL=/api

# Optional: required when backend APP_ENV=production and SETTINGS_API_KEY is set.
# Must match backend SETTINGS_API_KEY (settings PUT + reset only).
# VITE_SETTINGS_WRITE_KEY=change_me
