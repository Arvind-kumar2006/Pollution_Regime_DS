DATABASE_URL=postgresql://postgres:password@localhost:5432/pollution_db
# Comma-separated origins for browser clients, or * for dev (wildcard disables credentials)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:8000
UPLOAD_MAX_MB=50
SQL_ECHO=false
APP_ENV=development
# Settings write protection (required in production for PUT/POST /settings*)
# SETTINGS_API_KEY=change_me
